#: pages/code-chinois.php:57
msgid ""
"Le Code Chinois est <strong>l'inverse du Code des Samouraïs</strong>. On "
"commence la lecture par les traits <strong>horizontaux</strong> (qui "
"représentent la voyelle), puis les traits <strong>verticaux</strong> (qui "
"avancent dans l'alphabet)."
msgstr ""
"The Chinese Code is <strong>the reverse of the Samurai Code</strong>. "
"Reading starts with the <strong>horizontal</strong> strokes (which "
"represent the vowel), then the <strong>vertical</strong> strokes (which "
"advance through the alphabet)."

#: pages/code-chinois.php:60
msgid "Voyelles = traits horizontaux :"
msgstr "Vowels = horizontal strokes:"

#: pages/code-chinois.php:61
msgid "Consonnes = voyelle horizontale + traits verticaux"
msgstr "Consonants = horizontal vowel + vertical strokes"

#: pages/code-chinois.php:62
msgid "Séparateurs :"
msgstr "Separators:"

#: pages/code-chinois.php:62
msgid "\\ sépare les mots · \\\\ sépare les phrases"
msgstr "\\ separates words · \\\\ separates sentences"

#: pages/code-chinois.php:63
