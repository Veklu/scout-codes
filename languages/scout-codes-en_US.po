msgstr "SAMURAI"

#: pages/code-chinois.php:70
msgid "Verticaux d'abord → Horizontaux"
msgstr "Vertical first → Horizontal"

#: pages/code-chinois.php:76
msgid "CHINOIS"
msgstr "CHINESE"

#: pages/code-chinois.php:77
msgid "Horizontaux d'abord → Verticaux"
